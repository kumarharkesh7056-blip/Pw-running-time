body{
margin:0;
font-family:Arial;
background:#0f172a;
color:white;
}

header{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px;
background:#ff6b00;
}

.logo{
font-size:25px;
font-weight:bold;
}

nav a{
color:white;
text-decoration:none;
margin:10px;
}

.hero{
text-align:center;
padding:60px 20px;
}

.hero input{
padding:12px;
width:250px;
border-radius:8px;
border:none;
}

.hero button{
padding:12px 20px;
background:#ff6b00;
border:none;
color:white;
border-radius:8px;
margin-left:10px;
}

.courses{
display:flex;
justify-content:center;
gap:20px;
padding:30px;
flex-wrap:wrap;
}

.card{
background:#1e293b;
padding:20px;
border-radius:15px;
width:250px;
text-align:center;
}

.card:hover{
transform:scale(1.05);
transition:.3s;
}

footer{
text-align:center;
padding:20px;
background:#111827;
}
